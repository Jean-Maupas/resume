# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=your-secret-here

# Admin password hash — generate with: node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword', 12))"
ADMIN_PASSWORD_HASH=$2b$12$...

# Public URL of your site (used for absolute links in emails etc.)
PUBLIC_SITE_URL=https://maupas.org
